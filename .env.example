# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token
# Secret for webhook signature verification (set via setWebhook secret_token param)
TELEGRAM_WEBHOOK_SECRET=your-random-secret

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Monetization (disabled by default) ───────────────────────────────────────
# Set to true to restore legacy paid PRO flows and payment UI.
NEXT_PUBLIC_MONETIZATION_ENABLED=false
# Set false to restrict cron Telegram reminders back to legacy paid users only.
TELEGRAM_NOTIFICATIONS_FOR_FREE_USERS=true
# Max Telegram-linked users processed by the daily notification cron.
NOTIFY_CRON_MAX_USERS=500
# Max users processed in parallel per Telegram notification batch.
NOTIFY_CRON_TELEGRAM_BATCH_SIZE=20

# ─── Legacy TON Payments (used only when monetization is enabled) ─────────────
TON_WALLET_ADDRESS=your-ton-wallet-address
# Secret for verifying TonConsole webhook signatures
TONCONSOLE_WEBHOOK_SECRET=your-tonconsole-webhook-secret

# ─── OCR receipt scanning (OpenAI vision) ────────────────────────────────────
# Enables the "Scan receipt/screenshot" button in the Add-subscription form.
# Server-side only — never exposed to the client. If unset, the button is hidden.
OPENAI_API_KEY=sk-your-openai-key
# Optional overrides (defaults shown):
# OCR_MODEL=gpt-4o-mini
# OCR_LIMIT_PER_DAY=20      # scans per user per day
# OCR_LIMIT_BURST=5         # scans per user per minute
# OCR_LIMIT_GLOBAL=1000     # global scans per day (cost circuit breaker)

# ─── TMA Analytics ──────────────────────────────────────────────────────────
NEXT_PUBLIC_TMA_ANALYTICS_TOKEN=your-tma-analytics-token

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.subeasy.org

# ─── Vercel Cron (auto-managed by Vercel, not set manually) ──────────────────
# CRON_SECRET is injected automatically by Vercel for cron jobs
